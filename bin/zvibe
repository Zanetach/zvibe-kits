#!/usr/bin/env bash
set -euo pipefail

# -----------------------------
# Zvibe (Ghostty Dev Layout)
# -----------------------------
# Commands:
#   zvibe setup                         One-shot bootstrap (install + config)
#   zvibe install [all|deps|agents]      Explicit install (default: all)
#   zvibe doctor                         Check env + print fix commands
#   zvibe update                         Upgrade all brew deps (formula + cask)
#   zvibe [mode] [dir]                   Run layout (no auto-install)
#
# Modes:
#   codex    -> right pane runs Codex (via npx)
#   claude   -> right pane runs Claude Code (command: claude)
#   opencode -> right pane runs OpenCode (command: opencode)
#   code     -> dual agents from config AgentMode: [A, B]
#
# Config:
#   ~/.config/vibe/config.json
#   {
#     "defaultAgent": "codex",
#     "AgentMode": ["opencode","codex"]
#   }
#
# Env:
#   VIBE_CONFIG=/path/to/config.json
#   VIBE_AUTO_GIT_INIT=1|0          (default 1)
#   VIBE_AUTO_FIRST_COMMIT=1|0      (default 1)

# ---------- UI helpers ----------
print_logo() {
cat <<'EOF'
  ______     _ _        _        _  ___ _ _     
 |___  /    (_) |      | |      | |/ (_) | |    
    / /_   _ _| |__ ___| | _____| ' / _| | |_   
   / /| | | | | '_ \_  / |/ / _ \  < | | | __|  
  / /_| |_| | | |_) / /|   <  __/ . \| | | |_   
 /_____\__,_|_|_.__/___|_|\_\___|_|\_\_|_|\__|  

                 Zvibe Kits
EOF
}

hr() { printf "------------------------------------------------------------\n"; }
info() { printf "ℹ️  %s\n" "$*"; }
ok()   { printf "✅ %s\n" "$*"; }
warn() { printf "⚠️  %s\n" "$*"; }
err()  { printf "❌ %s\n" "$*" >&2; }
die()  { err "$*"; exit 1; }

step() {
  # step "Title" command...
  local title="$1"; shift
  printf "\n🧩 %s\n" "$title"
  hr
  "$@" || return 1
  return 0
}

# ---------- basic helpers ----------
have() { command -v "$1" >/dev/null 2>&1; }
need_macos() {
  [[ "$(uname -s)" == "Darwin" ]] || die "Zvibe currently supports macOS only (osascript + Ghostty)."
}

# ---------- config loading ----------
CONFIG_PATH="${VIBE_CONFIG:-$HOME/.config/vibe/config.json}"

CFG_DEFAULT_AGENT=""
CFG_AGENTMODE_1=""
CFG_AGENTMODE_2=""

load_config() {
  [[ -f "$CONFIG_PATH" ]] || return 0
  have python3 || return 0

  eval "$(
    python3 - <<'PY' "$CONFIG_PATH"
import json, sys
p=sys.argv[1]
try:
  data=json.load(open(p,'r',encoding='utf-8'))
except Exception:
  sys.exit(0)

def esc(s):
  if s is None: return ""
  return str(s).replace("\\","\\\\").replace('"','\\"')

defaultAgent = data.get("defaultAgent","")
agentMode = data.get("AgentMode", [])
a1 = agentMode[0] if isinstance(agentMode, list) and len(agentMode)>0 else ""
a2 = agentMode[1] if isinstance(agentMode, list) and len(agentMode)>1 else ""

print(f'CFG_DEFAULT_AGENT="{esc(defaultAgent)}"')
print(f'CFG_AGENTMODE_1="{esc(a1)}"')
print(f'CFG_AGENTMODE_2="{esc(a2)}"')
PY
  )"
}

is_agent() { case "${1:-}" in codex|claude|opencode) return 0 ;; *) return 1 ;; esac; }
is_mode()  { case "${1:-}" in codex|claude|opencode|code) return 0 ;; *) return 1 ;; esac; }

load_config

auto_git_init="${VIBE_AUTO_GIT_INIT:-1}"
auto_first_commit="${VIBE_AUTO_FIRST_COMMIT:-1}"

# ---------- brew helpers ----------
ensure_brew() {
  if have brew; then return 0; fi
  die "Homebrew not found.
Install it first:
  /bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\"
Then run:
  zvibe install"
}

brew_tap() { ensure_brew; brew tap "$1" >/dev/null 2>&1 || true; }
brew_install() { ensure_brew; info "brew install $*"; brew install "$@"; }
brew_install_cask() { ensure_brew; info "brew install --cask $*"; brew install --cask "$@"; }

# ---------- unified install catalog ----------
install_deps() {
  need_macos

  # osascript is built-in
  have osascript || die "osascript missing (unexpected on macOS)."

  if ! have git; then
    brew_install git
  else
    ok "git already installed"
  fi

  if ! have node || ! have npm || ! have npx; then
    brew_install node
  else
    ok "node/npm/npx already installed"
  fi
}

install_agents() {
  need_macos

  if ! have yazi; then
    brew_install yazi
  else
    ok "yazi already installed"
  fi

  if ! have keifu; then
    info "tap: trasta298/tap"
    brew_tap "trasta298/tap"
    brew_install "trasta298/tap/keifu"
  else
    ok "keifu already installed"
  fi

  if ! have claude; then
    brew_install_cask claude-code
  else
    ok "Claude Code (claude) already installed"
  fi

  if ! have opencode; then
    info "tap: anomalyco/tap"
    brew_tap "anomalyco/tap"
    brew_install "anomalyco/tap/opencode"
  else
    ok "OpenCode (opencode) already installed"
  fi

  if [[ ! -d "/Applications/Ghostty.app" ]]; then
    brew_install_cask ghostty
  else
    ok "Ghostty.app already installed"
  fi
}

create_default_config_if_missing() {
  if [[ -f "$CONFIG_PATH" ]]; then
    ok "config exists: $CONFIG_PATH"
    return 0
  fi

  info "creating config: $CONFIG_PATH"
  mkdir -p "$(dirname "$CONFIG_PATH")"
  cat > "$CONFIG_PATH" <<'JSON'
{
  "defaultAgent": "codex",
  "AgentMode": ["opencode", "codex"]
}
JSON
  ok "config created"
}

doctor() {
  need_macos

  printf "\n🩺 Zvibe Doctor\n"
  hr
  info "Config: ${CONFIG_PATH}"
  info "defaultAgent: ${CFG_DEFAULT_AGENT:-<unset>}"
  info "AgentMode: [${CFG_AGENTMODE_1:-<unset>}, ${CFG_AGENTMODE_2:-<unset>}]"
  hr

  local ok_all=1
  show_ok() { printf "✅ %-14s %s\n" "$1" "$2"; }
  show_miss() { ok_all=0; printf "❌ %-14s %s\n" "$1" "MISSING"; printf "   ↳ Fix: %s\n" "$2"; }

  have brew && show_ok "homebrew" "OK" || show_miss "homebrew" "/bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""
  have git && show_ok "git" "OK" || show_miss "git" "brew install git"
  have npx && show_ok "npx" "OK" || show_miss "npx" "brew install node"

  have yazi && show_ok "yazi" "OK" || show_miss "yazi" "brew install yazi"
  have keifu && show_ok "keifu" "OK" || show_miss "keifu" "brew tap trasta298/tap && brew install trasta298/tap/keifu"
  have claude && show_ok "claude" "OK" || show_miss "claude" "brew install --cask claude-code"
  have opencode && show_ok "opencode" "OK" || show_miss "opencode" "brew tap anomalyco/tap && brew install anomalyco/tap/opencode"

  [[ -d "/Applications/Ghostty.app" ]] && show_ok "Ghostty.app" "OK" || show_miss "Ghostty.app" "brew install --cask ghostty"
  have osascript && show_ok "osascript" "OK" || show_miss "osascript" "unexpected on macOS"

  hr
  if [[ "$ok_all" -eq 1 ]]; then
    ok "Environment looks good"
  else
    warn "Missing items found"
    info "Next: zvibe install"
    exit 2
  fi
}

update() {
  need_macos
  ensure_brew

  clear
  print_logo
  printf "\n"

  info "Updating Homebrew index..."
  brew update

  printf "\n🧾 Outdated formulae:\n"
  brew outdated || true

  printf "\n🧾 Outdated casks:\n"
  brew outdated --cask || true

  printf "\n🧩 Upgrading formulae...\n"
  brew upgrade || true

  printf "\n🧩 Upgrading casks...\n"
  brew upgrade --cask || true

  printf "\n🧹 Cleaning up...\n"
  brew cleanup || true

  printf "\n"
  ok "All dependencies updated."
}

setup() {
  need_macos
  clear
  print_logo
  printf "\n"
  info "Zvibe setup started"
  hr

  step "Install dependencies (git, node/npx)" install_deps || die "deps install failed"
  step "Install agents (yazi, keifu, claude-code, opencode, ghostty)" install_agents || die "agents install failed"
  step "Create config if missing" create_default_config_if_missing || die "config step failed"

  printf "\n"
  ok "Setup complete"
  info "Try:"
  info "  zvibe            # start defaultAgent (single)"
  info "  zvibe codex      # start Codex (single)"
  info "  zvibe claude     # start Claude Code (single)"
  info "  zvibe opencode   # start OpenCode (single)"
  info "  zvibe code       # start dual agents (AgentMode)"
  info "  zvibe update     # update all deps"
  printf "\n"
}

check_outdated() {
  have brew || return 0

  local outdated_formula
  local outdated_cask

  outdated_formula=$(brew outdated --quiet 2>/dev/null || true)
  outdated_cask=$(brew outdated --cask --quiet 2>/dev/null || true)

  local count=0
  if [[ -n "$outdated_formula" ]]; then
    count=$((count + $(echo "$outdated_formula" | wc -l | tr -d ' ')))
  fi
  if [[ -n "$outdated_cask" ]]; then
    count=$((count + $(echo "$outdated_cask" | wc -l | tr -d ' ')))
  fi

  if [[ "$count" -gt 0 ]]; then
    printf "\n⚠️  %d dependencies outdated.\n" "$count"
    printf "ℹ️  Run: zvibe update\n\n"
  fi
}

# ---------- run parsing ----------
MODE=""
TARGET_DIR=""

parse_run_args() {
  local a1="${1:-}"
  local a2="${2:-}"

  if is_mode "$a1"; then
    MODE="$a1"
    TARGET_DIR="${a2:-$(pwd)}"
  elif is_mode "$a2"; then
    MODE="$a2"
    TARGET_DIR="${a1:-$(pwd)}"
  else
    MODE=""  # no mode => single agent from defaultAgent
    TARGET_DIR="${a1:-$(pwd)}"
  fi

  [[ -z "$TARGET_DIR" ]] && TARGET_DIR="$(pwd)"

  if [[ -z "$MODE" ]]; then
    MODE="${CFG_DEFAULT_AGENT:-codex}"
    is_agent "$MODE" || die "config defaultAgent must be codex|claude|opencode (got: $MODE)"
  fi
}

agent_cmd() {
  local agent="$1"
  case "$agent" in
    codex)
      have npx || die "npx missing. Run: zvibe install"
      echo "npx --yes @openai/codex"
      ;;
    claude)
      have claude || die "Claude Code missing. Run: zvibe install"
      echo "claude"
      ;;
    opencode)
      have opencode || die "OpenCode missing. Run: zvibe install"
      echo "opencode"
      ;;
    *)
      die "Invalid agent: $agent (use: codex|claude|opencode)"
      ;;
  esac
}

run_layout() {
  need_macos

  # Notify updates (do not block)
  check_outdated

  # Explicit install only; do not install here
  have osascript || die "osascript missing (unexpected on macOS)."
  [[ -d "/Applications/Ghostty.app" ]] || die "Ghostty.app not found. Run: zvibe install"
  have yazi || die "yazi missing. Run: zvibe install"
  have keifu || die "keifu missing. Run: zvibe install"

  local cmd_yazi="cd ${TARGET_DIR} && yazi"
  local cmd_keifu="cd ${TARGET_DIR} && keifu"
  local cmd_right=""
  local cmd_right2=""

  case "$MODE" in
    code)
      local a="${CFG_AGENTMODE_1:-claude}"
      local b="${CFG_AGENTMODE_2:-codex}"
      is_agent "$a" || die "config AgentMode[0] must be codex|claude|opencode (got: $a)"
      is_agent "$b" || die "config AgentMode[1] must be codex|claude|opencode (got: $b)"
      cmd_right="cd ${TARGET_DIR} && $(agent_cmd "$a")"
      cmd_right2="cd ${TARGET_DIR} && $(agent_cmd "$b")"
      ;;
    codex|claude|opencode)
      cmd_right="cd ${TARGET_DIR} && $(agent_cmd "$MODE")"
      cmd_right2=""
      ;;
    *)
      die "Unknown mode: $MODE (use: codex|claude|opencode|code)"
      ;;
  esac

  # auto git init (optional)
  if [[ "$auto_git_init" == "1" ]]; then
    if [[ ! -d "${TARGET_DIR}/.git" ]]; then
      have git || die "git missing. Run: zvibe install"
      info "git init: ${TARGET_DIR}"
      (cd "${TARGET_DIR}" && git init >/dev/null 2>&1) || die "git init failed: ${TARGET_DIR}"

      if [[ "$auto_first_commit" == "1" ]]; then
        ( cd "${TARGET_DIR}" && git add -A >/dev/null 2>&1 && git commit -m "init: zvibe workspace" >/dev/null 2>&1 ) || true
      fi
    fi
  fi

  # Ghostty automation (your original keystrokes)
  osascript \
    -e 'on run argv' \
    -e '    set cmd_yazi to item 1 of argv' \
    -e '    set cmd_keifu to item 2 of argv' \
    -e '    set cmd_right to item 3 of argv' \
    -e '    set cmd_right2 to item 4 of argv' \
    -e '    tell application "Ghostty" to activate' \
    -e '    tell application "System Events"' \
    -e '        tell process "Ghostty"' \
    -e '            keystroke "d" using command down' \
    -e '            delay 0.25' \
    -e '            key code 4 using {control down, option down}' \
    -e '            delay 0.1' \
    -e '            set the clipboard to cmd_yazi' \
    -e '            keystroke "v" using command down' \
    -e '            keystroke return' \
    -e '            delay 0.4' \
    -e '            keystroke "d" using {command down, shift down}' \
    -e '            delay 0.25' \
    -e '            set the clipboard to cmd_keifu' \
    -e '            keystroke "v" using command down' \
    -e '            keystroke return' \
    -e '            delay 0.15' \
    -e '            key code 37 using {control down, option down}' \
    -e '            delay 0.1' \
    -e '            set the clipboard to cmd_right' \
    -e '            keystroke "v" using command down' \
    -e '            keystroke return' \
    -e '            delay 0.25' \
    -e '            if cmd_right2 is not "" then' \
    -e '                keystroke "d" using {command down, shift down}' \
    -e '                delay 0.2' \
    -e '                set the clipboard to cmd_right2' \
    -e '                keystroke "v" using command down' \
    -e '                keystroke return' \
    -e '                delay 0.2' \
    -e '            end if' \
    -e '        end tell' \
    -e '    end tell' \
    -e 'end run' \
    -- "${cmd_yazi}" "${cmd_keifu}" "${cmd_right}" "${cmd_right2}"
}

usage() {
  cat <<'EOF'
Usage:
  zvibe setup
  zvibe install [all|deps|agents]
  zvibe doctor
  zvibe update
  zvibe [mode] [dir]
  zvibe [dir] [mode]

Modes:
  codex | claude | opencode | code

Examples:
  zvibe setup
  zvibe doctor
  zvibe install
  zvibe update
  zvibe
  zvibe codex
  zvibe claude ~/proj
  zvibe ~/proj opencode
  zvibe code

Config:
  ~/.config/vibe/config.json
  {
    "defaultAgent": "codex",
    "AgentMode": ["opencode","codex"]
  }
EOF
}

main() {
  local sub="${1:-}"

  case "$sub" in
    setup)
      setup
      ;;
    install)
      shift || true
      local what="${1:-all}"
      case "$what" in
        all|"")
          clear
          print_logo
          info "Installing everything..."
          step "Install dependencies" install_deps || die "deps install failed"
          step "Install agents" install_agents || die "agents install failed"
          ok "Install complete"
          ;;
        deps)
          clear
          print_logo
          step "Install dependencies" install_deps || die "deps install failed"
          ok "Deps install complete"
          ;;
        agents)
          clear
          print_logo
          step "Install agents" install_agents || die "agents install failed"
          ok "Agents install complete"
          ;;
        *)
          die "Unknown install target: $what (use: all|deps|agents)"
          ;;
      esac
      ;;
    doctor)
      doctor
      ;;
    update)
      update
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      parse_run_args "${1:-}" "${2:-}"
      run_layout
      ;;
  esac
}

main "$@"
